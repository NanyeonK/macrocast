data_cache/
~/.macrocast/

# Python artifacts
__pycache__/
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/

# R build artifacts
macrocastR/.Rproj.user/
macrocastR/src/*.o
macrocastR/src/*.so

# IDE
.idea/
.vscode/

# Large binary files
*.xlsx
*.csv.gz
*.parquet

# LaTeX build
paper/*.aux
paper/*.log
paper/*.bbl
paper/*.blg
paper/*.fls
paper/*.fdb_latexmk
paper/*.synctex.gz
