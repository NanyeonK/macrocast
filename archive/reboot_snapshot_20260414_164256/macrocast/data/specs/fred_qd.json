{
  "dataset": "FRED-QD",
  "frequency": "quarterly",
  "source_url": "https://files.stlouisfed.org/files/htdocs/fred-md/quarterly/current.csv",
  "vintage_url_template": "https://files.stlouisfed.org/files/htdocs/fred-md/quarterly/{vintage}.csv",
  "reference": "McCracken & Ng (2016)",
  "groups": {
    "nipa": "National Income and Product Accounts",
    "labor": "Labor Market",
    "housing": "Housing",
    "money_credit": "Money and Credit",
    "interest_exchange": "Interest and Exchange Rates",
    "prices": "Prices",
    "stock_market": "Stock Market",
    "financial": "Financial Markets"
  },
  "variables": {
    "GDPC1": {"description": "Real Gross Domestic Product", "group": "nipa", "tcode": 5},
    "GDPPOT": {"description": "Real Potential Gross Domestic Product", "group": "nipa", "tcode": 5},
    "PCECC96": {"description": "Real Personal Consumption Expenditures", "group": "nipa", "tcode": 5},
    "GPDIC1": {"description": "Real Gross Private Domestic Investment", "group": "nipa", "tcode": 5},
    "EXPGSC1": {"description": "Real Exports", "group": "nipa", "tcode": 5},
    "IMPGSC1": {"description": "Real Imports", "group": "nipa", "tcode": 5},
    "GCEC1": {"description": "Real Government Consumption Expenditures", "group": "nipa", "tcode": 5},
    "ULCNFB": {"description": "Nonfarm Business Sector: Unit Labor Cost", "group": "nipa", "tcode": 6},
    "UNRATE": {"description": "Civilian Unemployment Rate", "group": "labor", "tcode": 2},
    "PAYEMS": {"description": "All Employees: Total Nonfarm", "group": "labor", "tcode": 5},
    "CE16OV": {"description": "Civilian Employment", "group": "labor", "tcode": 5},
    "CLF16OV": {"description": "Civilian Labor Force", "group": "labor", "tcode": 5},
    "COMPNFB": {"description": "Nonfarm Business: Real Compensation Per Hour", "group": "labor", "tcode": 5},
    "OPHNFB": {"description": "Nonfarm Business: Output Per Hour of All Persons", "group": "labor", "tcode": 5},
    "HOANBS": {"description": "Nonfarm Business: Hours of All Persons", "group": "labor", "tcode": 5},
    "HOUST": {"description": "Housing Starts", "group": "housing", "tcode": 4},
    "PERMIT": {"description": "New Private Housing Building Permits", "group": "housing", "tcode": 4},
    "FEDFUNDS": {"description": "Effective Federal Funds Rate", "group": "interest_exchange", "tcode": 2},
    "TB3MS": {"description": "3-Month Treasury Bill Rate", "group": "interest_exchange", "tcode": 2},
    "GS10": {"description": "10-Year Treasury Constant Maturity Rate", "group": "interest_exchange", "tcode": 2},
    "BAA": {"description": "Moody's Baa Corporate Bond Yield", "group": "interest_exchange", "tcode": 2},
    "AAA": {"description": "Moody's Aaa Corporate Bond Yield", "group": "interest_exchange", "tcode": 2},
    "M1SL": {"description": "M1 Money Stock", "group": "money_credit", "tcode": 6},
    "M2SL": {"description": "M2 Money Stock", "group": "money_credit", "tcode": 6},
    "BUSLOANS": {"description": "Commercial and Industrial Loans", "group": "money_credit", "tcode": 6},
    "CPIAUCSL": {"description": "CPI: All Items", "group": "prices", "tcode": 6},
    "PCEPI": {"description": "PCE: Chain-type Price Index", "group": "prices", "tcode": 6},
    "GDPDEF": {"description": "Gross Domestic Product: Implicit Price Deflator", "group": "prices", "tcode": 6},
    "OILPRICEx": {"description": "Crude Oil Prices: WTI", "group": "prices", "tcode": 5},
    "SP500": {"description": "S&P 500 Index", "group": "stock_market", "tcode": 5},
    "TWEXBMTH": {"description": "Trade Weighted U.S. Dollar Index", "group": "interest_exchange", "tcode": 5}
  }
}
